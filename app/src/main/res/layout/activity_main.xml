<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B1020">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#11182D">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎰 ThaiClub AutoBet Pro"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adaptive UI • Full script parity • Variable betting"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#11182D"
                android:padding="12dp"
                android:layout_marginBottom="10dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Login Mode" android:textColor="#22C55E" android:textStyle="bold" android:textSize="12sp"/>
                <Spinner android:id="@+id/spLoginMode" android:layout_width="match_parent" android:layout_height="44dp" android:background="#1E293B" android:layout_marginTop="6dp"/>
                <EditText android:id="@+id/etJwt" android:layout_width="match_parent" android:layout_height="80dp" android:hint="JWT token" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:gravity="top" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Username / Phone" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Password" android:inputType="textPassword" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <Button android:id="@+id/btnConnect" android:layout_width="match_parent" android:layout_height="48dp" android:text="🚀 Connect &amp; Verify" android:textStyle="bold" android:backgroundTint="#22C55E" android:textColor="#08111F" android:layout_marginTop="10dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#11182D" android:padding="12dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Core Settings" android:textColor="#38BDF8" android:textStyle="bold" android:textSize="12sp"/>
                <Spinner android:id="@+id/spGame" android:layout_width="match_parent" android:layout_height="44dp" android:background="#1E293B" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spBetMode" android:layout_width="match_parent" android:layout_height="44dp" android:background="#1E293B" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spStrategy" android:layout_width="match_parent" android:layout_height="44dp" android:background="#1E293B" android:layout_marginTop="8dp"/>
                <Spinner android:id="@+id/spProgressive" android:layout_width="match_parent" android:layout_height="44dp" android:background="#1E293B" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etFixedAmount" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Fixed/Base Amount" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etVariableAmounts" android:layout_width="match_parent" android:layout_height="60dp" android:hint="Variable amounts e.g. 10,20,30,40" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:gravity="top" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etMaxRounds" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Max rounds" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#11182D" android:padding="12dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Adaptive Controls" android:textColor="#F59E0B" android:textStyle="bold" android:textSize="12sp"/>
                <EditText android:id="@+id/etRandomOppositeRate" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Random opposite rate %" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etProgressiveMax" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Progressive max" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etStopProfit" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Stop profit" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etStopLoss" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Stop loss" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etBalanceAlertLow" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Balance alert low" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etBalanceAlertHigh" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Balance alert high" android:inputType="numberDecimal" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#11182D" android:padding="12dp" android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Timing Engine" android:textColor="#A78BFA" android:textStyle="bold" android:textSize="12sp"/>
                <EditText android:id="@+id/etTrigger1" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Trigger second #1" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etTrigger2" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Trigger second #2 (for 30s mode)" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etFetch1" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Fetch issue at #1" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etFetch2" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Fetch issue at #2" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etBalanceCheck1" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Balance check #1" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etBalanceCheck2" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Balance check #2" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/etSettlementDelay" android:layout_width="match_parent" android:layout_height="44dp" android:hint="Settlement delay seconds" android:inputType="number" android:textColor="#E2E8F0" android:textColorHint="#64748B" android:background="#1E293B" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btnStart" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="▶ Start" android:textStyle="bold" android:backgroundTint="#22C55E" android:textColor="#08111F" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnPause" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:text="⏸ Pause" android:backgroundTint="#334155" android:textColor="#FFFFFF" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btnBalance" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="💰 Balance" android:backgroundTint="#1E293B" android:textColor="#FFFFFF" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="💾 Save Config" android:backgroundTint="#1E293B" android:textColor="#FFFFFF" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="📊 History" android:backgroundTint="#1E293B" android:textColor="#FFFFFF" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Not connected" android:textColor="#CBD5E1" android:textSize="12sp" android:background="#11182D" android:padding="10dp"/>
            <TextView android:id="@+id/tvStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rounds: 0 | Wins: 0 | Losses: 0 | Wagered: 0" android:textColor="#22C55E" android:textSize="12sp" android:background="#11182D" android:padding="10dp" android:layout_marginTop="8dp"/>
            <TextView android:id="@+id/tvBalance" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Balance: --" android:textColor="#FBBF24" android:textStyle="bold" android:textSize="14sp" android:background="#11182D" android:padding="10dp" android:layout_marginTop="8dp"/>
            <TextView android:id="@+id/tvLog" android:layout_width="match_parent" android:layout_height="220dp" android:gravity="top" android:text="Ready..." android:textColor="#93C5FD" android:textSize="11sp" android:background="#020617" android:padding="10dp" android:layout_marginTop="8dp" android:fontFamily="monospace"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>