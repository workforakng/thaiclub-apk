<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface" android:padding="14dp" android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🎰 ThaiClub AutoBet v3.2"
            android:textColor="@color/accent" android:textSize="17sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvBalance" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="💰 --"
            android:textColor="@color/green" android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface" android:paddingStart="10dp" android:paddingEnd="10dp"
        android:paddingBottom="8dp" android:orientation="horizontal">
        <Button android:id="@+id/tabJwt" android:layout_width="0dp" android:layout_height="38dp"
            android:layout_weight="1" android:text="JWT Token" android:textSize="12sp"
            android:backgroundTint="@color/accent" android:textColor="@color/bg"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/tabCred" android:layout_width="0dp" android:layout_height="38dp"
            android:layout_weight="1" android:text="User / Pass" android:textSize="12sp"
            android:backgroundTint="@color/surface2" android:textColor="@color/text"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="10dp">

            <!-- JWT panel -->
            <LinearLayout android:id="@+id/panelJwt" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@color/surface" android:padding="12dp"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="JWT Bearer Token" android:textColor="@color/accent"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="5dp"/>
                <EditText android:id="@+id/etJwt" android:layout_width="match_parent"
                    android:layout_height="80dp" android:background="@color/surface2"
                    android:textColor="@color/text" android:textColorHint="@color/textDim"
                    android:hint="Paste Bearer token..." android:gravity="top"
                    android:padding="10dp" android:textSize="11sp" android:inputType="textMultiLine"/>
            </LinearLayout>

            <!-- Cred panel -->
            <LinearLayout android:id="@+id/panelCred" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:background="@color/surface" android:padding="12dp"
                android:layout_marginBottom="8dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Phone (with country code)" android:textColor="@color/accent"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="5dp"/>
                <EditText android:id="@+id/etUsername" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@color/surface2"
                    android:textColor="@color/text" android:textColorHint="@color/textDim"
                    android:hint="918102516848" android:padding="10dp"
                    android:inputType="phone" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Password" android:textColor="@color/accent"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="5dp"/>
                <EditText android:id="@+id/etPassword" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@color/surface2"
                    android:textColor="@color/text" android:textColorHint="@color/textDim"
                    android:hint="Password" android:padding="10dp" android:inputType="textPassword"/>
            </LinearLayout>

            <!-- Config -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface"
                android:padding="12dp" android:layout_marginBottom="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Game Mode" android:textColor="@color/accent" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spGame" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@color/surface2"
                    android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Strategy" android:textColor="@color/accent" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spStrategy" android:layout_width="match_parent"
                    android:layout_height="44dp" android:background="@color/surface2"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bet Amount (₹)" android:textColor="@color/textDim"
                            android:textSize="11sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etBetAmount" android:layout_width="match_parent"
                            android:layout_height="44dp" android:background="@color/surface2"
                            android:textColor="@color/text" android:text="10"
                            android:inputType="numberDecimal" android:padding="10dp" android:textSize="15sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Max Rounds" android:textColor="@color/textDim"
                            android:textSize="11sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etRounds" android:layout_width="match_parent"
                            android:layout_height="44dp" android:background="@color/surface2"
                            android:textColor="@color/text" android:text="10"
                            android:inputType="number" android:padding="10dp" android:textSize="15sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <Button android:id="@+id/btnConnect" android:layout_width="match_parent"
                android:layout_height="50dp" android:text="🚀  CONNECT &amp; VERIFY"
                android:textSize="14sp" android:textStyle="bold"
                android:backgroundTint="@color/accent" android:textColor="@color/bg"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tvStatus" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Not connected"
                android:textColor="@color/textDim" android:textSize="12sp"
                android:gravity="center" android:layout_marginBottom="8dp"/>

            <!-- Stats -->
            <LinearLayout android:id="@+id/statsRow" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:visibility="gone" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface2" android:gravity="center"
                    android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rounds" android:textColor="@color/textDim" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvRounds" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/accent" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface2" android:gravity="center"
                    android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Wins" android:textColor="@color/textDim" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvWins" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/green" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface2" android:gravity="center"
                    android:layout_marginEnd="3dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Losses" android:textColor="@color/textDim" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvLosses" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textColor="@color/red" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface2" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="P/L ₹" android:textColor="@color/textDim" android:textSize="9sp"/>
                    <TextView android:id="@+id/tvPL" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.00"
                        android:textColor="@color/yellow" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Clock + progress -->
            <TextView android:id="@+id/tvClock" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text=""
                android:textColor="@color/textDim" android:textSize="10sp"
                android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
            <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="6dp"
                android:max="100" android:progress="0" android:progressTint="@color/accent"
                android:layout_marginBottom="8dp"/>

            <!-- Log -->
            <ScrollView android:id="@+id/logScrollView" android:layout_width="match_parent"
                android:layout_height="180dp" android:background="@color/surface"
                android:layout_marginBottom="8dp">
                <TextView android:id="@+id/tvLog" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Waiting...
"
                    android:textColor="@color/textDim" android:textSize="10sp"
                    android:fontFamily="monospace" android:padding="8dp"/>
            </ScrollView>

            <!-- Start / Pause -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnStart" android:layout_width="0dp"
                    android:layout_height="52dp" android:layout_weight="1"
                    android:text="▶  START" android:textSize="14sp" android:textStyle="bold"
                    android:backgroundTint="@color/accent" android:textColor="@color/bg"
                    android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnPause" android:layout_width="0dp"
                    android:layout_height="52dp" android:layout_weight="1"
                    android:text="⏸  PAUSE" android:textSize="13sp"
                    android:backgroundTint="@color/surface2" android:textColor="@color/text"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Bottom row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btnRefresh" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:text="💰 Bal" android:textSize="11sp"
                    android:backgroundTint="@color/surface2" android:textColor="@color/text"
                    android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btnHistory" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:text="📊 History" android:textSize="11sp"
                    android:backgroundTint="@color/surface2" android:textColor="@color/text"
                    android:layout_marginEnd="3dp"/>
                <Button android:id="@+id/btnSettings" android:layout_width="0dp"
                    android:layout_height="40dp" android:layout_weight="1"
                    android:text="⚙️ Settings" android:textSize="11sp"
                    android:backgroundTint="@color/surface2" android:textColor="@color/text"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
